# --- Database -----------------------------------------------------------------
# Replace this DATABASE_URL with your Supabase Connection String.
# Go to your Supabase project settings -> Database -> Connection string -> URI
# Ensure you construct the asyncpg driver URL like:
# DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@[YOUR-DB-HOST].supabase.co:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@[YOUR-DB-HOST].supabase.co:6543/postgres

# --- Redis --------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- JWT Auth -----------------------------------------------------------------
SECRET_KEY=change_this_to_a_long_random_string_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Algorand -----------------------------------------------------------------
# Use AlgoNode free public endpoints for TestNet (no sign-up required)
ALGORAND_NODE_URL=https://testnet-api.algonode.cloud
ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud
ALGORAND_NETWORK=testnet

# Deployer wallet mnemonic (25 words) — fund this on TestNet faucet
# https://bank.testnet.algorand.network/
ALGORAND_DEPLOYER_MNEMONIC=word1 word2 word3 ... word25

# Deployed contract app IDs (filled after running deploy scripts)
IDENTITY_APP_ID=0
CONSENT_REGISTRY_APP_ID=0
PROOF_VERIFIER_APP_ID=0
COMPLIANCE_CERT_APP_ID=0

# --- Frontend -----------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ALGORAND_NETWORK=testnet
